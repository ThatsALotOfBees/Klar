# gitattributes is "last-match wins" per attribute. Put the catch-all
# default first; the binary overrides for client-releases/** + media
# files MUST come after, otherwise the catch-all's eol=lf wins and
# defeats the purpose.

# Default: detect text files, store with LF in the index. Source files
# in this repo are LF regardless of the user's autocrlf setting.
* text=auto eol=lf

# Auto-update bundle MUST be byte-exact end-to-end. release-client.cjs
# computes a SHA256 of each snapshot file, the manifest stores it, and
# the renderer verifies the same hash after downloading from
# raw.githubusercontent.com. Any line-ending conversion between snapshot
# and serving breaks the integrity check ("sha256 mismatch for app.js").
client-releases/** -text

# Sounds + media must never be touched.
*.mp3 -text
*.wav -text
*.ogg -text
*.mp4 -text
*.webm -text
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text

# WebAssembly modules — byte-exact binary. Same reasoning as
# client-releases/** above: sha256s computed by release-client.cjs
# would mismatch if git ever line-ending-normalized these.
*.wasm -text
